@article{wireduEffectGreenSupply2024,
  title = {The Effect of Green Supply Chain Management Practices on Corporate Environmental Performance: {{Does}} Supply Chain Competitive Advantage Matter?},
  shorttitle = {The Effect of Green Supply Chain Management Practices on Corporate Environmental Performance},
  author = {Wiredu, John and Yang, Qian and Sampene, Agyemang Kwasi and Gyamfi, Bright Akwasi and Asongu, Simplice A.},
  year = 2024,
